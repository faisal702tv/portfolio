# Database
DATABASE_URL="file:./prisma/dev.db"

# Docker production (optional override inside container)
# DOCKER_DATABASE_URL="file:/app/data/portfolio.db"

# Security: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# App URL (for CORS, redirects, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3333"

# Reverse Proxy / TLS (Caddy)
# DOMAIN="example.com"
# ACME_EMAIL="admin@example.com"

# Optional: Redis URL for rate limiting (production)
# REDIS_URL="redis://localhost:6379"

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=""

# Encryption key for API keys (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))")
ENCRYPTION_KEY=""

# ══════════════════════════════════════════
# AI Provider API Keys (set at least one)
# ══════════════════════════════════════════

# OpenAI - https://platform.openai.com/api-keys
# OPENAI_API_KEY=""

# Groq (free tier) - https://console.groq.com/keys
# GROQ_API_KEY=""

# DeepSeek - https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=""

# OpenRouter (free models available) - https://openrouter.ai/keys
# OPENROUTER_API_KEY=""

# Anthropic Claude - https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=""

# Google AI (Gemini) - https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=""

# xAI (Grok) - https://console.x.ai
# XAI_API_KEY=""

# Cohere - https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=""

# Mistral - https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=""
